---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="hero">
  <h1>{title}</h1>
  {subtitle && <p>{subtitle}</p>}
</section>

<style>
  .hero {
    background: linear-gradient(135deg, #1e1b4b, #2563eb);
    color: white;
    padding: 4rem 2rem;
    border-radius: 12px;
    margin-bottom: 2.5rem;
    text-align: center;
  }

  h1 {
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }

  p {
    font-size: 1.1rem;
    color: #bfdbfe;
  }
</style>
