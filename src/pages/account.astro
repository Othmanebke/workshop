---
export const prerender = false;

import Layout from '../layouts/Layout.astro';

const STRAPI = import.meta.env.PUBLIC_STRAPI_URL ?? 'http://127.0.0.1:1337';

const jwt = Astro.cookies.get('jwt')?.value;
if (!jwt) return Astro.redirect('/login');

// Récupère l'utilisateur courant
const meRes = await fetch(`${STRAPI}/api/users/me`, {
  headers: { Authorization: `Bearer ${jwt}` },
});

if (!meRes.ok) {
  Astro.cookies.delete('jwt',      { path: '/' });
  Astro.cookies.delete('loggedIn', { path: '/' });
  return Astro.redirect('/login');
}

let user = await meRes.json();

let erreur = '';
let succes = false;

// Traitement du formulaire de mise à jour
if (Astro.request.method === 'POST') {
  const data      = await Astro.request.formData();
  const prenom    = data.get('prenom')?.toString()    ?? '';
  const nom       = data.get('nom')?.toString()       ?? '';
  const telephone = data.get('telephone')?.toString() ?? '';
  const username  = data.get('username')?.toString()  ?? '';

  const updateRes = await fetch(`${STRAPI}/api/users/${user.id}`, {
    method: 'PUT',
    headers: {
      'Content-Type': 'application/json',
      Authorization: `Bearer ${jwt}`,
    },
    body: JSON.stringify({ prenom, nom, telephone, username }),
  });

  const json = await updateRes.json();

  if (updateRes.ok) {
    succes = true;
    user = json; // rafraîchit les données affichées
  } else {
    erreur = json.error?.message ?? 'Une erreur est survenue.';
  }
}
---

<Layout title="Mon compte">
  <div class="account-wrapper">

    <!-- En-tête profil -->
    <header class="account-header">
      <div class="avatar">{user.username.charAt(0).toUpperCase()}</div>
      <div>
        <h1>
          {user.prenom || user.nom
            ? `${user.prenom ?? ''} ${user.nom ?? ''}`.trim()
            : user.username}
        </h1>
        <p class="email">{user.email}</p>
      </div>
    </header>

    <!-- Formulaire de modification -->
    <section class="card">
      <h2>Modifier mon profil</h2>

      {succes && (
        <p class="succes">Profil mis à jour avec succès !</p>
      )}
      {erreur && (
        <p class="erreur">{erreur}</p>
      )}

      <form method="POST">
        <div class="grid-2">
          <div class="field">
            <label for="prenom">Prénom</label>
            <input
              id="prenom"
              name="prenom"
              type="text"
              value={user.prenom ?? ''}
              autocomplete="given-name"
            />
          </div>
          <div class="field">
            <label for="nom">Nom</label>
            <input
              id="nom"
              name="nom"
              type="text"
              value={user.nom ?? ''}
              autocomplete="family-name"
            />
          </div>
        </div>

        <div class="field">
          <label for="username">Nom d'utilisateur</label>
          <input
            id="username"
            name="username"
            type="text"
            value={user.username}
            required
            autocomplete="username"
          />
        </div>

        <div class="field">
          <label for="telephone">Téléphone</label>
          <input
            id="telephone"
            name="telephone"
            type="tel"
            value={user.telephone ?? ''}
            autocomplete="tel"
          />
        </div>

        <!-- Email en lecture seule -->
        <div class="field">
          <label>Email</label>
          <input type="email" value={user.email} disabled />
          <span class="hint">L'email ne peut pas être modifié ici.</span>
        </div>

        <button type="submit">Enregistrer les modifications</button>
      </form>
    </section>

    <!-- Infos du compte -->
    <section class="card">
      <h2>Informations du compte</h2>
      <dl>
        <div>
          <dt>Rôle</dt>
          <dd>{user.role?.name ?? 'Authenticated'}</dd>
        </div>
        <div>
          <dt>Membre depuis</dt>
          <dd>
            {new Date(user.createdAt).toLocaleDateString('fr-FR', {
              day: 'numeric', month: 'long', year: 'numeric',
            })}
          </dd>
        </div>
      </dl>
    </section>

    <a href="/logout" class="btn-logout">Se déconnecter</a>
  </div>
</Layout>

<style>
  .account-wrapper {
    max-width: 620px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .account-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #2563eb;
    color: white;
    font-size: 1.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 0.2rem;
  }

  .email {
    color: #71717a;
    font-size: 0.9rem;
  }

  .card {
    background: white;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.07);
    padding: 1.75rem 2rem;
  }

  h2 {
    font-size: 0.85rem;
    font-weight: 700;
    color: #71717a;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 1.25rem;
  }

  .succes {
    background: #f0fdf4;
    color: #16a34a;
    border: 1px solid #bbf7d0;
    border-radius: 6px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
  }

  .erreur {
    background: #fef2f2;
    color: #dc2626;
    border: 1px solid #fecaca;
    border-radius: 6px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #3f3f46;
  }

  input {
    border: 1px solid #e4e4e7;
    border-radius: 6px;
    padding: 0.6rem 0.875rem;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
    background: white;
  }

  input:focus {
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  input:disabled {
    background: #f4f4f5;
    color: #a1a1aa;
    cursor: not-allowed;
  }

  .hint {
    font-size: 0.78rem;
    color: #a1a1aa;
  }

  button[type='submit'] {
    align-self: flex-start;
    background: #2563eb;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 0.6rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }

  button[type='submit']:hover {
    background: #1d4ed8;
  }

  dl {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  dl > div {
    display: flex;
    justify-content: space-between;
    padding-bottom: 0.875rem;
    border-bottom: 1px solid #f4f4f5;
  }

  dl > div:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  dt { font-size: 0.875rem; color: #71717a; }
  dd { font-size: 0.9rem; font-weight: 600; }

  .btn-logout {
    display: inline-block;
    align-self: flex-start;
    background: #fef2f2;
    color: #dc2626;
    border: 1px solid #fecaca;
    border-radius: 6px;
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s;
  }

  .btn-logout:hover {
    background: #fee2e2;
    text-decoration: none;
  }
</style>
