---
export const prerender = false;

import Layout from '../layouts/Layout.astro';

const STRAPI = import.meta.env.PUBLIC_STRAPI_URL ?? 'http://127.0.0.1:1337';
let erreur = '';

if (Astro.request.method === 'POST') {
  const data       = await Astro.request.formData();
  const identifier = data.get('identifier')?.toString() ?? '';
  const password   = data.get('password')?.toString() ?? '';

  const res = await fetch(`${STRAPI}/api/auth/local`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ identifier, password }),
  });

  const json = await res.json();

  if (res.ok) {
    // JWT httpOnly — lu uniquement côté serveur Astro
    Astro.cookies.set('jwt', json.jwt, {
      httpOnly: true,
      path: '/',
      maxAge: 60 * 60 * 24 * 7, // 7 jours
      sameSite: 'lax',
    });
    // Cookie UI — lu par le JS du Header pour afficher "Mon compte"
    Astro.cookies.set('loggedIn', '1', {
      path: '/',
      maxAge: 60 * 60 * 24 * 7,
      sameSite: 'lax',
    });
    return Astro.redirect('/account');
  } else {
    erreur = json.error?.message ?? 'Identifiants incorrects.';
  }
}
---

<Layout title="Connexion">
  <div class="auth-wrapper">
    <div class="auth-card">
      <h1>Connexion</h1>

      {erreur && <p class="erreur">{erreur}</p>}

      <form method="POST">
        <label for="identifier">Email ou nom d'utilisateur</label>
        <input
          id="identifier"
          name="identifier"
          type="text"
          required
          autocomplete="username"
        />

        <label for="password">Mot de passe</label>
        <input
          id="password"
          name="password"
          type="password"
          required
          autocomplete="current-password"
        />

        <button type="submit">Se connecter</button>
      </form>

      <div class="auth-links">
        <a href="/forgot-password">Mot de passe oublié ?</a>
        <span>·</span>
        <a href="/register">Créer un compte</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .auth-wrapper {
    display: flex;
    justify-content: center;
    padding: 2rem 1rem;
  }

  .auth-card {
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    padding: 2.5rem;
    width: 100%;
    max-width: 420px;
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 1.75rem;
  }

  .erreur {
    background: #fef2f2;
    color: #dc2626;
    border: 1px solid #fecaca;
    border-radius: 6px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #3f3f46;
    margin-top: 0.5rem;
  }

  input {
    border: 1px solid #e4e4e7;
    border-radius: 6px;
    padding: 0.6rem 0.875rem;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
  }

  input:focus {
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  button[type='submit'] {
    margin-top: 1rem;
    background: #2563eb;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 0.7rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }

  button[type='submit']:hover {
    background: #1d4ed8;
  }

  .auth-links {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    font-size: 0.875rem;
    color: #71717a;
  }
</style>
