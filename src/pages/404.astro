---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page introuvable" description="Cette page n'existe pas.">
  <div class="wrapper">
    <p class="code">404</p>
    <h1>Page introuvable</h1>
    <p class="message">La page que tu cherches n'existe pas ou a été déplacée.</p>
    <a href="/" class="btn">Retour à l'accueil</a>
  </div>
</Layout>

<style>
  .wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 5rem 1rem;
    gap: 1rem;
  }

  .code {
    font-size: 6rem;
    font-weight: 900;
    color: #e4e4e7;
    line-height: 1;
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 800;
  }

  .message {
    color: #71717a;
    font-size: 1rem;
  }

  .btn {
    margin-top: 0.5rem;
    display: inline-block;
    background: #2563eb;
    color: white;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.15s;
  }

  .btn:hover {
    background: #1d4ed8;
    text-decoration: none;
  }
</style>
