---
export const prerender = false;

import Layout from '../layouts/Layout.astro';

// Le token envoyé par Strapi dans l'email
const STRAPI = import.meta.env.PUBLIC_STRAPI_URL ?? 'http://127.0.0.1:1337';
const code = Astro.url.searchParams.get('code') ?? '';

let erreur = '';
let succes = false;

if (!code) {
  return Astro.redirect('/forgot-password');
}

if (Astro.request.method === 'POST') {
  const data                = await Astro.request.formData();
  const password            = data.get('password')?.toString() ?? '';
  const passwordConfirmation = data.get('passwordConfirmation')?.toString() ?? '';

  if (password !== passwordConfirmation) {
    erreur = 'Les mots de passe ne correspondent pas.';
  } else {
    const res = await fetch(`${STRAPI}/api/auth/reset-password`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ code, password, passwordConfirmation }),
    });

    const json = await res.json();

    if (res.ok) {
      succes = true;
    } else {
      erreur = json.error?.message ?? 'Lien invalide ou expiré.';
    }
  }
}
---

<Layout title="Réinitialiser le mot de passe">
  <div class="auth-wrapper">
    <div class="auth-card">
      <h1>Nouveau mot de passe</h1>

      {succes ? (
        <div class="succes">
          <p>Mot de passe modifié avec succès !</p>
          <a href="/login">Se connecter</a>
        </div>
      ) : (
        <>
          {erreur && <p class="erreur">{erreur}</p>}

          <form method="POST">
            {/* Le code est passé en query string, on le remet dans l'action */}
            <input type="hidden" name="code" value={code} />

            <label for="password">Nouveau mot de passe</label>
            <input
              id="password"
              name="password"
              type="password"
              required
              minlength="6"
              autocomplete="new-password"
            />

            <label for="passwordConfirmation">Confirmer le mot de passe</label>
            <input
              id="passwordConfirmation"
              name="passwordConfirmation"
              type="password"
              required
              minlength="6"
              autocomplete="new-password"
            />

            <button type="submit">Réinitialiser</button>
          </form>
        </>
      )}
    </div>
  </div>
</Layout>

<style>
  .auth-wrapper {
    display: flex;
    justify-content: center;
    padding: 2rem 1rem;
  }

  .auth-card {
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    padding: 2.5rem;
    width: 100%;
    max-width: 420px;
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 1.75rem;
  }

  .erreur {
    background: #fef2f2;
    color: #dc2626;
    border: 1px solid #fecaca;
    border-radius: 6px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
  }

  .succes {
    background: #f0fdf4;
    color: #16a34a;
    border: 1px solid #bbf7d0;
    border-radius: 6px;
    padding: 1rem;
    font-size: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .succes a {
    font-weight: 600;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #3f3f46;
    margin-top: 0.5rem;
  }

  input[type='password'] {
    border: 1px solid #e4e4e7;
    border-radius: 6px;
    padding: 0.6rem 0.875rem;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
  }

  input[type='password']:focus {
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  button[type='submit'] {
    margin-top: 1rem;
    background: #2563eb;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 0.7rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }

  button[type='submit']:hover {
    background: #1d4ed8;
  }
</style>
